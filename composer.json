{
    "name": "toitzi/laravel-cloudflare-mail",
    "description": "Cloudflare Email Service transport for Laravel mailers.",
    "type": "library",
    "homepage": "https://github.com/toitzi/laravel-cloudflare-mail",
    "license": "MIT",
    "authors": [
        {
            "name": "Tobias Oitzinger",
            "email": "hello@toitzi.dev",
            "homepage": "https://toitzi.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/mail": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "symfony/mailer": "^8.0",
        "symfony/mime": "^8.0 "
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Toitzi\\LaravelCloudflareMail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Toitzi\\LaravelCloudflareMail\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Toitzi\\LaravelCloudflareMail\\CloudflareMailServiceProvider"
            ]
        }
    }
}
